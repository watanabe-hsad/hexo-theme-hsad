extends ./_partial/base.pug

block content
  - var tags = site.tags ? (typeof site.tags.toArray === 'function' ? site.tags.toArray() : (site.tags.data || [])) : []
  - tags = tags.filter(function(tag) { return tag.length; }).sort(function(a, b) { return b.length - a.length; })
  section.page-intro
    p.page-intro__kicker Overview
    h1.page-intro__title 标签
    p.page-intro__description= tags.length ? `${tags.length} 个标签，用来更快地翻找内容。` : '暂时还没有标签。'
  if tags.length
    .tag-cloud
      each tag in tags
        a.tag-cloud__item(href=url_for(tag.path))
          span.tag-cloud__name= tag.name
          span.tag-cloud__count= tag.length
  else
    .empty-state
      h2.empty-state__title 暂时还没有标签
      p.empty-state__text 等以后再慢慢长出来。
